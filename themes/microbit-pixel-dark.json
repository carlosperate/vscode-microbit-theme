  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5a6e60",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Doc",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#5a6e60",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#f08a3c"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#4cd07a"
      }
    },
    {
      "name": "Template Expression",
      "scope": [
        "meta.template.expression",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#6a7b6f"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#b89cf0"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#c7b4f0"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#d6e0d8"
      }
    },
    {
      "name": "Variable Parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c7b4f0"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "meta.property.object",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#92c5e0"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#5cd9d6",
        "fontStyle": ""
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5cd9d6"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#ef7aae"
      }
    },
    {
      "name": "Builtin Type",
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#ef7aae"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#6ab7e8"
      }
    },
    {
      "name": "Method",
      "scope": [
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#6ab7e8"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#f08a3c"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#8aa395"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#6a7b6f"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#4cd07a"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#ef7aae"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c7b4f0"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#ef7aae",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#6ab7e8"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#5cd9d6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#f08a3c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#6ab7e8"
      }
    },
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#92c5e0"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#ffffff",
        "background": "#cd0365"
      }
    }
  ],
  "semanticTokenColors": {
    "variable.readonly": {
      "foreground": "#c7b4f0"
    },
    "variable.defaultLibrary": {
      "foreground": "#6ab7e8"
    },
    "property.readonly": {
      "foreground": "#92c5e0"
    },
    "parameter": {
      "foreground": "#c7b4f0"
    },
    "class": {
      "foreground": "#ef7aae"
    },
    "interface": {
      "foreground": "#ef7aae"
    },
    "enum": {
      "foreground": "#ef7aae"
    },
    "type": {
      "foreground": "#ef7aae"
    },
    "typeParameter": {
      "foreground": "#c7b4f0",
      "italic": true
    },
    "function": {
      "foreground": "#6ab7e8"
    },
    "method": {
      "foreground": "#6ab7e8"
    },
    "namespace": {
      "foreground": "#ef7aae"
    },
    "keyword": {
      "foreground": "#5cd9d6"
    },
    "decorator": {
      "foreground": "#f08a3c"
    },
    "regexp": {
      "foreground": "#4cd07a"
    }
  }
}
