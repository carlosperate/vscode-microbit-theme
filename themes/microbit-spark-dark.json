{
  "$schema": "vscode://schemas/color-theme",
  "name": "micro:bit Spark Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#1c0e0b",
    "editor.foreground": "#e6d8cc",
    "editor.lineHighlightBackground": "rgba(231,100,92,0.05)",
    "editor.lineHighlightBorder": "#00000000",
    "editor.selectionBackground": "rgba(231,100,92,0.26)",
    "editor.inactiveSelectionBackground": "rgba(231,100,92,0.26)",
    "editor.findMatchBackground": "rgba(231,100,92,0.16)",
    "editor.findMatchHighlightBackground": "rgba(231,100,92,0.16)",
    "editor.wordHighlightBackground": "rgba(231,100,92,0.16)",
    "editorCursor.foreground": "#f08aa8",
    "editorLineNumber.foreground": "#574238",
    "editorLineNumber.activeForeground": "#e6d8cc",
    "editorBracketMatch.background": "rgba(231,100,92,0.16)",
    "editorBracketMatch.border": "#f08aa8",
    "editorWhitespace.foreground": "#57423855",
    "editorIndentGuide.background": "#23170f",
    "editorIndentGuide.activeBackground": "#574238",
    "editorRuler.foreground": "#23170f",
    "editorBracketHighlight.foreground1": "#f08aa8",
    "editorBracketHighlight.foreground2": "#f5a070",
    "editorBracketHighlight.foreground3": "#c7b4f0",
    "editorBracketHighlight.foreground4": "#f08aa8",
    "editorBracketHighlight.foreground5": "#f5a070",
    "editorBracketHighlight.foreground6": "#c7b4f0",
    "editorBracketHighlight.unexpectedBracket.foreground": "#cd0365",
    "editorGutter.background": "#1c0e0b",
    "editorGutter.modifiedBackground": "#f08aa8",
    "editorGutter.addedBackground": "#4cd07a",
    "editorGutter.deletedBackground": "#c7b4f0",
    "titleBar.activeBackground": "#150a0a",
    "titleBar.activeForeground": "#c2a39a",
    "titleBar.inactiveBackground": "#150a0a",
    "titleBar.inactiveForeground": "#8a6e64",
    "titleBar.border": "#2a1d1a",
    "activityBar.background": "#3a0a1c",
    "activityBar.foreground": "#f08aa8",
    "activityBar.inactiveForeground": "rgba(240,138,168,0.50)",
    "activityBar.activeBorder": "#f08aa8",
    "activityBar.activeBackground": "#00000000",
    "activityBar.border": "#3a0a1c",
    "activityBarBadge.background": "#6ab7e8",
    "activityBarBadge.foreground": "#ffffff",
    "sideBar.background": "#1a0e0c",
    "sideBar.foreground": "#dbc6ba",
    "sideBar.border": "#2a1d1a",
    "sideBarTitle.foreground": "#8a6e64",
    "sideBarSectionHeader.background": "#1a0e0c",
    "sideBarSectionHeader.foreground": "#8a6e64",
    "sideBarSectionHeader.border": "#23170f",
    "list.activeSelectionBackground": "#33181a",
    "list.activeSelectionForeground": "#dbc6ba",
    "list.inactiveSelectionBackground": "#33181a",
    "list.inactiveSelectionForeground": "#dbc6ba",
    "list.hoverBackground": "#241413",
    "list.hoverForeground": "#dbc6ba",
    "list.focusBackground": "#33181a",
    "list.focusForeground": "#dbc6ba",
    "list.focusOutline": "#f08aa8",
    "list.highlightForeground": "#f08aa8",
    "tree.indentGuidesStroke": "#23170f",
    "editorGroupHeader.tabsBackground": "#150a0a",
    "editorGroupHeader.tabsBorder": "#2a1d1a",
    "editorGroupHeader.border": "#2a1d1a",
    "tab.activeBackground": "#1c0e0b",
    "tab.activeForeground": "#f5e8db",
    "tab.activeBorderTop": "#f08aa8",
    "tab.activeBorder": "#1c0e0b",
    "tab.inactiveBackground": "#150a0a",
    "tab.inactiveForeground": "#7a5e54",
    "tab.hoverBackground": "#241413",
    "tab.border": "#2a1d1a",
    "tab.unfocusedActiveBorderTop": "#23170f",
    "editorGroup.border": "#2a1d1a",
    "breadcrumb.background": "#1c0e0b",
    "breadcrumb.foreground": "#8a6e64",
    "breadcrumb.focusForeground": "#e6d8cc",
    "breadcrumb.activeSelectionForeground": "#f08aa8",
    "statusBar.background": "#a83a3a",
    "statusBar.foreground": "#fbeae6",
    "statusBar.border": "#a83a3a",
    "statusBar.noFolderBackground": "#a83a3a",
    "statusBar.debuggingBackground": "#f08aa8",
    "statusBarItem.hoverBackground": "#ffffff22",
    "statusBarItem.remoteBackground": "#00000022",
    "statusBarItem.remoteForeground": "#fbeae6",
    "statusBarItem.prominentBackground": "#00000022",
    "statusBarItem.errorBackground": "#cd0365",
    "statusBarItem.warningBackground": "#b85a00",
    "panel.background": "#1c0e0b",
    "panel.border": "#2a1d1a",
    "panelTitle.activeForeground": "#e6d8cc",
    "panelTitle.inactiveForeground": "#8a6e64",
    "panelTitle.activeBorder": "#f08aa8",
    "terminal.background": "#1c0e0b",
    "terminal.foreground": "#e6d8cc",
    "terminal.ansiBlack": "#0a120e",
    "terminal.ansiRed": "#cd0365",
    "terminal.ansiGreen": "#00a000",
    "terminal.ansiYellow": "#e7645c",
    "terminal.ansiBlue": "#2a94d6",
    "terminal.ansiMagenta": "#6c4bc1",
    "terminal.ansiCyan": "#7bcdc2",
    "terminal.ansiWhite": "#d6e0d8",
    "terminal.ansiBrightBlack": "#3e4d44",
    "terminal.ansiBrightRed": "#e7645c",
    "terminal.ansiBrightGreen": "#4cd07a",
    "terminal.ansiBrightYellow": "#f5a070",
    "terminal.ansiBrightBlue": "#6ab7e8",
    "terminal.ansiBrightMagenta": "#b4a3e8",
    "terminal.ansiBrightCyan": "#9ee0d6",
    "terminal.ansiBrightWhite": "#ffffff",
    "minimap.background": "#1a0e0c",
    "minimap.selectionHighlight": "#f08aa8",
    "minimapSlider.background": "rgba(231,100,92,0.16)",
    "minimapSlider.hoverBackground": "rgba(231,100,92,0.16)",
    "minimapSlider.activeBackground": "rgba(231,100,92,0.16)",
    "minimapGutter.modifiedBackground": "#f08aa8",
    "minimapGutter.addedBackground": "#4cd07a",
    "minimapGutter.deletedBackground": "#c7b4f0",
    "input.background": "#1c0e0b",
    "input.foreground": "#e6d8cc",
    "input.border": "#2a1d1a",
    "input.placeholderForeground": "#8a6e64",
    "inputOption.activeBorder": "#f08aa8",
    "dropdown.background": "#1c0e0b",
    "dropdown.foreground": "#e6d8cc",
    "dropdown.border": "#2a1d1a",
    "button.background": "#f08aa8",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#f08aa8cc",
    "badge.background": "#f08aa8",
    "badge.foreground": "#ffffff",
    "notificationCenter.border": "#2a1d1a",
    "notifications.background": "#1a0e0c",
    "notifications.foreground": "#dbc6ba",
    "notifications.border": "#2a1d1a",
    "textLink.foreground": "#f08aa8",
    "textLink.activeForeground": "#f08aa8",
    "editorLink.activeForeground": "#f08aa8",
    "focusBorder": "#f08aa8",
    "contrastBorder": "#00000000",
    "scrollbar.shadow": "#00000022",
    "scrollbarSlider.background": "#57423844",
    "scrollbarSlider.hoverBackground": "#57423866",
    "scrollbarSlider.activeBackground": "#57423888"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a5e54",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Doc",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#7a5e54",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#c7b4f0"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#4cd07a"
      }
    },
    {
      "name": "Template Expression",
      "scope": [
        "meta.template.expression",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#8a6e64"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#6ab7e8"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#c7b4f0"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#e6d8cc"
      }
    },
    {
      "name": "Variable Parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c7b4f0"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "meta.property.object",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#f5b48c"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#f08aa8",
        "fontStyle": ""
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f08aa8"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#5cd9d6"
      }
    },
    {
      "name": "Builtin Type",
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#5cd9d6"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#f5a070"
      }
    },
    {
      "name": "Method",
      "scope": [
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#f5a070"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#f08aa8"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#a08577"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#8a6e64"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#4cd07a"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#f08aa8"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c7b4f0"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#5cd9d6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#f5a070"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f08aa8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#c7b4f0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#f5a070"
      }
    },
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#f5b48c"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#ffffff",
        "background": "#cd0365"
      }
    }
  ],
  "semanticTokenColors": {
    "variable.readonly": {
      "foreground": "#c7b4f0"
    },
    "variable.defaultLibrary": {
      "foreground": "#f5a070"
    },
    "property.readonly": {
      "foreground": "#f5b48c"
    },
    "parameter": {
      "foreground": "#c7b4f0"
    },
    "class": {
      "foreground": "#5cd9d6"
    },
    "interface": {
      "foreground": "#5cd9d6"
    },
    "enum": {
      "foreground": "#5cd9d6"
    },
    "type": {
      "foreground": "#5cd9d6"
    },
    "typeParameter": {
      "foreground": "#c7b4f0",
      "italic": true
    },
    "function": {
      "foreground": "#f5a070"
    },
    "method": {
      "foreground": "#f5a070"
    },
    "namespace": {
      "foreground": "#5cd9d6"
    },
    "keyword": {
      "foreground": "#f08aa8"
    },
    "decorator": {
      "foreground": "#f08aa8"
    },
    "regexp": {
      "foreground": "#4cd07a"
    }
  }
}