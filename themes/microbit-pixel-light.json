    "peekViewResult.selectionForeground": "#3a4a35",
    "peekViewTitle.background": "#e6ebe1",
    "peekViewTitleLabel.foreground": "#1a2a1a",
    "peekViewTitleDescription.foreground": "#aab8a0",
