  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7d8c75",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Doc",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#7d8c75",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#b85a00"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#00a000"
      }
    },
    {
      "name": "Template Expression",
      "scope": [
        "meta.template.expression",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#5a6855"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#6c4bc1"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#5b3fb0"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#1a2a1a"
      }
    },
    {
      "name": "Variable Parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#6c4bc1"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "meta.property.object",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#1f6e8c"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#007575",
        "fontStyle": ""
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#007575"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#cd0365"
      }
    },
    {
      "name": "Builtin Type",
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#cd0365"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#2a94d6"
      }
    },
    {
      "name": "Method",
      "scope": [
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#2a94d6"
      }
    },
    {
      "name": "Decorator",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#b85a00"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#5a6855"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#5a6855"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#00a000"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#cd0365"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6c4bc1"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#cd0365",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#2a94d6"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#007575",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#b85a00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#2a94d6"
      }
    },
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#1f6e8c"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#ffffff",
        "background": "#cd0365"
      }
    }
  ],
  "semanticTokenColors": {
    "variable.readonly": {
      "foreground": "#5b3fb0"
    },
    "variable.defaultLibrary": {
      "foreground": "#2a94d6"
    },
    "property.readonly": {
      "foreground": "#1f6e8c"
    },
    "parameter": {
      "foreground": "#6c4bc1"
    },
    "class": {
      "foreground": "#cd0365"
    },
    "interface": {
      "foreground": "#cd0365"
    },
    "enum": {
      "foreground": "#cd0365"
    },
    "type": {
      "foreground": "#cd0365"
    },
    "typeParameter": {
      "foreground": "#6c4bc1",
      "italic": true
    },
    "function": {
      "foreground": "#2a94d6"
    },
    "method": {
      "foreground": "#2a94d6"
    },
    "namespace": {
      "foreground": "#cd0365"
    },
    "keyword": {
      "foreground": "#007575"
    },
    "decorator": {
      "foreground": "#b85a00"
    },
    "regexp": {
      "foreground": "#00a000"
    }
  }
}
